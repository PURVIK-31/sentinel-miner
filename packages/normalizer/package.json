    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json"
  },
  "dependencies": {
    "@sentinel/shared": "1.0.0"
  },
  "devDependencies": {
    "@sentinel/dsl": "1.0.0",
    "@sentinel/engine": "1.0.0"
  }
}
